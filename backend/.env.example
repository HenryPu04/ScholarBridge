# Pinecone (https://app.pinecone.io)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=scholarbridge
PINECONE_ENVIRONMENT=us-east-1-aws

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Authentication — generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — set to your Vercel URL in production
FRONTEND_URL=http://localhost:3000

# Database (SQLite for MVP — path relative to /backend)
DATABASE_URL=sqlite+aiosqlite:///./scholarbridge.db
